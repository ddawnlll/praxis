{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://praxis.local/schemas/evidence-bundle-v1.schema.json",
  "title": "EvidenceBundle",
  "description": "praxis-protocol/v1 — structured evidence pack covering a CandidateManifest. Records are bound to a Merkle root.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "candidateId",
    "merkleRoot",
    "attestation",
    "records"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "praxis-protocol/v1"
    },
    "candidateId": {
      "type": "string",
      "minLength": 1
    },
    "merkleRoot": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runnerDigest", "toolchain"],
      "properties": {
        "runnerDigest": {
          "type": "string",
          "pattern": "^[a-z0-9]+:[a-f0-9]{64}$"
        },
        "toolchain": {
          "type": "object",
          "additionalProperties": false,
          "required": ["language", "compiler", "version"],
          "properties": {
            "language": { "type": "string", "minLength": 1 },
            "compiler": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 }
          }
        },
        "dependencyLocks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "environmentFingerprint": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidenceRecord" }
    }
  },
  "$defs": {
    "evidenceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recordId", "kind", "capturedAt", "payload"],
      "properties": {
        "recordId": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "command.stdout",
            "command.stderr",
            "command.exit",
            "command.timedOut",
            "test.result",
            "coverage.line",
            "lint.report",
            "typecheck.report",
            "fs.diff",
            "policy.decision",
            "kill.signal",
            "promotion.event"
          ]
        },
        "capturedAt": { "type": "string", "format": "date-time" },
        "commandId": { "type": ["string", "null"] },
        "payload": { "type": "object" }
      }
    }
  }
}
